# Secrets — never commit
.env
*.env
**/.env
*.key
*.pem
.credentials.json

# Filled-in profile configs — carry private vault paths, project names and
# proprietary house standards. Only *.example.toml may be published.
# (legal-analysis moved to its own private repository 2026-07-22; its rule went
# with it. Keep this pattern generic so the next plugin with a profile config is
# covered without anyone remembering to add a line.)
**/config/*.toml
!**/config/*.example.toml
**/config/local.toml

# Node / build
node_modules/
.next/
dist/
build/

# Python runtime (should not live here anyway)
venv/
__pycache__/
*.pyc

# Heavy artifacts that belong on E:\-4-, never here
*.gguf
*.safetensors
*_cache/
downloads/
outputs/

# OS
.DS_Store
Thumbs.db
